@inherits LayoutComponentBase

<div class="d-flex flex-column min-vh-100">

    <!-- Modern Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm px-3">
        <a class="navbar-brand fw-semibold" href="">Code Review Assistant</a>

        <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-code-slash me-2"></i>Code Review
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/settings">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>Settings
                    </NavLink>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Content -->
    <main class="container py-4">
        @Body
    </main>

</div>
<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

<!-- Toast Container -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1050;">
    <div id="liveToast" class="toast align-items-center text-bg-primary border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body" id="toastBody">Notification</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>



