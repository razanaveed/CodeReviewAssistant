@page "/settings"
@using CodeReviewAssistant.Services
@inject SettingsService SettingsService

<div class="container mt-4">
    <div class="card glass-card">

        <h4>⚙️ AI Settings</h4>

        <div class="mb-3">
            <label>GROQ API Key</label>
            <input class="form-control" @bind="SettingsService.Settings.ApiKey" />
        </div>

        <div class="mb-3">
            <label>GROQ Model</label>
            <select class="form-select" @bind="SettingsService.Settings.Model">
                <option value="llama-3.1-8b-instant">llama-3.1-8b-instant</option>
                <option value="llama-3.3-70b-versatile">llama-3.3-70b-versatile</option>
                <option value="openai/gpt-oss-120b">openai/gpt-oss-120b</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Temperature: @SettingsService.Settings.Temperature</label>
            <input type="range" min="0" max="1" step="0.1"
                   class="form-range"
                   @bind="SettingsService.Settings.Temperature" />
        </div>
        <div class="mb-3">
            <label>Max Tokens: @SettingsService.Settings.MaxTokens</label>
            <input type="range" min="1" max="1024" step="1"
                   class="form-range"
                   @bind="SettingsService.Settings.MaxTokens" />
        </div>
        <div class="row">
            <div class="col">
                <label>Improvements</label>
                <input type="number" class="form-control"
                       @bind="SettingsService.Settings.ImprovementCount" />
            </div>

            <div class="col">
                <label>Positives</label>
                <input type="number" class="form-control"
                       @bind="SettingsService.Settings.PositiveCount" />
            </div>
        </div>

        <div class="form-check mt-3">
            <input type="checkbox" class="form-check-input"
                   @bind="SettingsService.Settings.IncludeRefactoredCode" />
            <label>Include Refactored Code</label>
        </div>

    </div>
</div>